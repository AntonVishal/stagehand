# Personalised Job Applier

# Required for real Browserbase + Stagehand browser runs.
# Without these, the app stays in safe local demo mode and stops at review.
BROWSERBASE_API_KEY=""
BROWSERBASE_PROJECT_ID=""

# Vercel AI Gateway API key (used by both Stagehand and AI SDK tailoring).
AI_GATEWAY_API_KEY=""
# OpenAI-compatible base URL for Stagehand LLM calls (chat completions).
AI_GATEWAY_BASE_URL="https://ai-gateway.vercel.sh/v1"
# Optional override for AI SDK Gateway provider (defaults to https://ai-gateway.vercel.sh/v4/ai).
# AI_GATEWAY_SDK_BASE_URL="https://ai-gateway.vercel.sh/v4/ai"
# Provider-prefixed model id (e.g. openai/gpt-5-mini).
AI_GATEWAY_MODEL="openai/gpt-5-mini"

# Optional: direct OpenAI key for non-Stagehand AI SDK material generation.
OPENAI_API_KEY=""

# Optional defaults.
DEFAULT_ROLE_QUERY="Product Engineer"
CANDIDATE_PROFILE_PATH=""
LATEX_TEMPLATE_DIR=""

# Optional override for development. Defaults to the local file dependency:
# @browserbasehq/stagehand -> file:../packages/core
STAGEHAND_PACKAGE_NAME="@browserbasehq/stagehand"
